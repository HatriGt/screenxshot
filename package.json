{
  "name": "screenxshot-monorepo",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "ScreenXShot monorepo — shared editor, web app, and desktop (Tauri) app.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @screenxshot/web",
    "build": "npm run build -w @screenxshot/web",
    "preview": "npm run preview -w @screenxshot/web",
    "test": "node --test packages/editor/src/**/*.test.js"
  }
}
