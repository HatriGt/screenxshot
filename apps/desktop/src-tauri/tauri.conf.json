{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ScreenXShot",
  "version": "1.0.0",
  "identifier": "com.screenxshot.app",
  "build": {
    "devUrl": "http://localhost:5174",
    "frontendDist": "../dist",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "ScreenXShot",
        "width": 1200,
        "height": 800,
        "minWidth": 720,
        "minHeight": 520,
        "decorations": false,
        "visible": false,
        "backgroundColor": "#14161f"
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Utility",
    "shortDescription": "Every screenshot, instantly beautiful.",
    "longDescription": "ScreenXShot beautifies and annotates screenshots entirely on your device — capture a region with a global hotkey, drop it on a backdrop, mark it up, and copy or save. Nothing is uploaded.",
    "copyright": "© ScreenXShot",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "active": false,
      "endpoints": [
        "https://releases.screenxshot.com/update/{{target}}/{{current_version}}"
      ],
      "pubkey": "REPLACE_WITH_TAURI_SIGNER_PUBLIC_KEY",
      "dialog": true
    }
  }
}
