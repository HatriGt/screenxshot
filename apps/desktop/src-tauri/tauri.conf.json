{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ScreenXShot",
  "version": "1.0.0",
  "identifier": "com.screenxshot.app",
  "build": {
    "devUrl": "http://localhost:5174",
    "frontendDist": "../dist",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ScreenXShot",
        "width": 1200,
        "height": 800,
        "minWidth": 720,
        "minHeight": 520
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Utility",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
